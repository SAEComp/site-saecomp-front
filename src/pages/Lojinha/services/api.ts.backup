import axios, { AxiosResponse } from 'axios';
import { 
  Product, 
  Order, 
  Payment, 
  PaymentMethod,
  PixPaymentRequest,
  PixPaymentResponse,
  ApiResponse, 
  ProductFilters,
  PixSettings,
  HistoryEntry,
  HistoryStats
} from '../types';
import authInterceptor from '../../../providers/authInterceptor';
import { 
  ProductBackend, 
  CartBackend, 
  OrderBackend, 
  FinishBuyResponse,
  StatisticsBackend,
  PixKeyBackend,
  BackendResponse
} from '../types/backend.types';
import {
  adaptProductFromBackend,
  adaptProductToBackend,
  adaptCartFromBackend,
  adaptOrderFromBackend,
  adaptFinishBuyToPixResponse,
  adaptStatisticsFromBackend,
  categoryFrontendToBackend
} from './apiAdapter';

const API_BASE_URL = import.meta.env.VITE_LOJINHA_API_URL || 'https://api.saecomp.com.br/api/lojinha';

const api = axios.create({
  baseURL: API_BASE_URL,
  headers: {
    'Content-Type': 'application/json',
  },
  timeout: 30000,
});

// Interceptor de autenticação para enviar o token do usuário logado
// Rotas públicas que não precisam de autenticação
api.interceptors.request.use(authInterceptor(['/products', '/payments', '/orders']));

// Interceptors para tratamento de erros
api.interceptors.response.use(
  (response: AxiosResponse) => response,
  (error) => {
    console.error('API Error:', error);
    
    if (error.code === 'ECONNABORTED') {
      return Promise.reject({ message: 'Timeout: Verifique sua conexão e tente novamente' });
    }
    
    if (error.code === 'ERR_NETWORK') {
      return Promise.reject({ message: 'Erro de rede: Verifique sua conexão' });
    }
    
    if (error.response?.data) {
      return Promise.reject(error.response.data);
    }
    
    return Promise.reject({ message: error.message || 'Erro de conexão' });
  }
);

// Produtos
export const getProducts = async (filters?: ProductFilters): Promise<ApiResponse<Product[]>> => {
  const params = new URLSearchParams();
  
  // Backend usa 'category' diretamente, não 'all'
  if (filters?.category && filters.category !== 'all') {
    const backendCategory = categoryFrontendToBackend[filters.category];
    params.append('category', backendCategory);
  }
  
  if (filters?.search) {
    params.append('search', filters.search);
  }
  
  try {
    const response = await api.get<BackendResponse<ProductBackend[]>>('/products', { params });
    const products = response.data.product || [];
    const adaptedProducts = products.map(adaptProductFromBackend);
    
    return {
      success: true,
      data: adaptedProducts
    };
  } catch (error) {
    console.error('❌ API error:', error);
    throw error;
  }
};

